<?xml version="1.0" encoding="utf-8"?>
<!--
  android/app/src/main/res/layout/focus_widget_small.xml

  IDs that FocusWidgetProvider.kt writes to:
    widget_root          — clickable container (opens app)
    widget_priority_dot  — emoji dot e.g. 🔴
    widget_project_name  — project name
    widget_priority_label — e.g. CRITICAL
    widget_timer         — ⏱ 25:00  or  ⏸ 12:34
    widget_task_summary  — "3 tasks · 1 overdue"  (hidden when empty)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp"
    android:gravity="center_vertical">

    <!-- Row 1: priority dot + project name -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_priority_dot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚪"
            android:textSize="13sp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/widget_project_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="No active project"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_priority_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#99FFFFFF"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:layout_marginStart="6dp" />

    </LinearLayout>

    <!-- Row 2: session timer -->
    <TextView
        android:id="@+id/widget_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏱ No active session"
        android:textColor="#99FFFFFF"
        android:textSize="11sp"
        android:layout_marginTop="4dp" />

    <!-- Row 3: task summary (visible only when non-empty; RemoteViews sets text) -->
    <TextView
        android:id="@+id/widget_task_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#66FFFFFF"
        android:textSize="10sp"
        android:layout_marginTop="2dp" />

</LinearLayout>